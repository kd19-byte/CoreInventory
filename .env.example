# Copy this file to .env.local (frontend) and .env (backend)
# Frontend
VITE_API_URL=http://localhost:4000/api

# Backend (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inventory_system
PORT=4000

# Backend auth
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=12h
RESET_JWT_SECRET=replace-this-with-another-long-random-secret
RESET_TOKEN_EXPIRES_IN=15m
OTP_EXPIRES_MINUTES=15
OTP_MAX_ATTEMPTS=5

# Backend mail (SMTP)
MAIL_PROVIDER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@example.com
MAIL_PASS=your-app-password
MAIL_FROM=CoreInventory <your-email@example.com>

# Backend mail (Resend API alternative)
# Set MAIL_PROVIDER=resend to use this
RESEND_API_KEY=
RESEND_FROM=CoreInventory <onboarding@resend.dev>
